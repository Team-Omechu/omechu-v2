# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8080

# Supabase (NEXT_PUBLIC_*는 브라우저/SSR 공개 설정)
SUPABASE_PROJECT_REF=xztldvunnasjaxnzqpct
NEXT_PUBLIC_SUPABASE_URL=https://xztldvunnasjaxnzqpct.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx

# ── 소셜 로그인 (Edge Function 통일 방식)
#
# Google / Kakao 모두 Supabase 네이티브 provider 대신 edge function(google-login,
# kakao-login)을 사용. OAuth 리다이렉트 URL에서 Supabase 서브도메인 노출을 피하고
# omechu.log8.kr 한 도메인으로 통일하기 위함.
#
# NEXT_PUBLIC_* 는 브라우저(authorize URL 구성용), 나머지는 Supabase edge function
# 시크릿으로 `supabase secrets set` 으로 등록. `.env*` 파일에는 문서·로컬 테스트용.

# Google OAuth (edge function google-login 사용)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Kakao OAuth (edge function kakao-login 사용)
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_js_key_here
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
KAKAO_CLIENT_SECRET=your_kakao_client_secret_here

# Site URL (for SEO metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAP_SERVER_API_KEY=your_google_map_server_api_key_here

# Embed API (optional)
NEXT_PUBLIC_EMBED_API_URL=https://embed.example.com

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=omechu
SENTRY_PROJECT=omechu-fe

# Google Analytics (GA4, 형식: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
